{
  "$schema": "https://unpkg.com",
  "ignore": [],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "prettier-plugin-tailwindcss"
      ]
    },
    "apps/api": {
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "superjson",
        "@repo/typescript-config"
      ]
    },
    "apps/web": {
      "entry": [
        "src/app/main.{ts,tsx}"
      ],
      "ignore": [
        "src/shared/lib/tanstack-table.d.ts",
        "src/shared/ui/*",
        "src/widgets/lot-details-view/ui/header.tsx"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "@fontsource-variable/*",
        "tailwindcss",
        "shadcn",
        "zod",
        "prettier-plugin-tailwindcss",
        "tw-animate-css"
      ]
    },
    "packages/db": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [],
      "ignoreDependencies": [
        "@prisma/client"
      ]
    },
    "packages/trpc": {
      "ignore": [],
      "ignoreDependencies": [
        "@repo/db",
        "@types/express",
        "@types/express-serve-static-core",
        "zod"
      ]
    }
  }
}