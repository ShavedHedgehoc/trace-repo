}

model Products {
  ProductId      String          @id(map: "PK__Products__B40CC6CDFE0DE0B7") @db.Char(6)
  ProductName    String?         @db.VarChar(200)
  ProductMarking String?         @db.VarChar(50)
  ProductBarcode String?         @db.Char(13)
  Acceptance     Acceptance[]
  Boils          Boils[]
  BtProducts     BtProducts[]
  CellsContains  CellsContains[]
  InventoryRows  InventoryRows[]
  Lots           Lots[]
