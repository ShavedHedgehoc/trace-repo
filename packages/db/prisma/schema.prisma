generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Acceptance {
  AcceptancePK    Int       @id(map: "AcceptancePK") @default(autoincrement())
  DocumentPK      Int
  ProductId       String    @db.Char(6)
  LotPK           Int
  ExpiredDate     DateTime  @db.DateTime
  BarrelsId       Int
  BarrelsCapacity Decimal   @db.Decimal(9, 5)
  BarrelsQuantity Int
  Barrels         Barrels   @relation(fields: [BarrelsId], references: [BarrelsId], onUpdate: NoAction, map: "FK_Acceptance_Barrels")
  Documents       Documents @relation(fields: [DocumentPK], references: [DocumentPK], onUpdate: NoAction, map: "FK_Acceptance_Documents")
  Lots            Lots      @relation(fields: [LotPK], references: [LotPK], onUpdate: NoAction, map: "FK_Acceptance_Lots")
  Products        Products  @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_Acceptance_Products")
}

model AuthorOccupations {
  AuthorOccupationsPK Int     @id(map: "PK__AuthorOccupa__0F0A858E271F6096") @default(autoincrement())
  AuthorPK            Int
  PlantPK             Int
  Authors             Authors @relation(fields: [AuthorPK], references: [AuthorPK], onUpdate: NoAction, map: "FK_AuthorOccupations_Authors")
  Plants              Plants  @relation(fields: [PlantPK], references: [PlantPK], onUpdate: NoAction, map: "FK_AuthorOccupations_Plants")

  @@index([AuthorPK], map: "IX_AuthorOccupations_Author")
  @@index([AuthorPK], map: "NonClusteredIndex-20251007-192636")
  @@index([PlantPK], map: "NonClusteredIndex-20251007-192648")
}

model Authors {
  AuthorPK          Int                 @id(map: "PK__Authors__70DA34D0BAC995CE") @default(autoincrement())
  AuthorName        String              @unique(map: "UC_Authors") @db.VarChar(50)
  AuthorBarcode     String?             @db.Char(13)
  AuthorOccupations AuthorOccupations[]
  BoilRecords       BoilRecords[]
  CanLocations      CanLocations[]
  CanRecords        CanRecords[]
  Documents         Documents[]
  InventoryRows     InventoryRows[]

  @@index([AuthorPK], map: "IX_Authors_PK_Name")
  @@index([AuthorPK], map: "NonClusteredIndex-20251007-161623")
  @@index([AuthorName], map: "NonClusteredIndex-20251007-161712")
}

model Barrels {
  BarrelsId   Int          @id(map: "PK_Barrels")
  BarrelsName String?      @db.VarChar(50)
  Acceptance  Acceptance[]
}

model Batchs {
  BatchPK     Int           @id(map: "PK__Batchs__5D56FBF9027E4597") @default(autoincrement())
  BatchName   String        @unique(map: "UC_Batchs") @db.VarChar(10)
  BatchDate   DateTime?     @db.DateTime
  Plant       String?       @db.NChar(1)
  BatchNumber Int?
  BatchMonth  String?       @db.VarChar(1)
  BatchYear   Int?
  BoilRecords BoilRecords[]
  Boils       Boils[]
  BtProducts  BtProducts[]
  CanRecords  CanRecords[]
  Loads       Loads[]
  Weightings  Weightings[]

  @@index([BatchDate, BatchName, Plant], map: "IX_Batchs_BatchDate_BatchName_Plant_BatchPK")
  @@index([BatchDate, Plant, BatchName], map: "IX_Batchs_BatchDate_Plant_BatchName")
  @@index([BatchDate], map: "NonClusteredIndex-20250921-151654")
  @@index([Plant], map: "NonClusteredIndex-20250921-151730")
  @@index([BatchNumber], map: "NonClusteredIndex-20251010-132714")
  @@index([BatchMonth], map: "NonClusteredIndex-20251010-132733")
  @@index([BatchYear], map: "NonClusteredIndex-20251010-132748")
}

model BoilRecords {
  BoilRecordsPK Int        @id(map: "PK_BoilRecords") @default(autoincrement())
  BatchId       Int
  OperationId   Int
  AuthorId      Int
  Temperature   Int?
  CreateDate    DateTime   @db.DateTime
  Authors       Authors    @relation(fields: [AuthorId], references: [AuthorPK], onUpdate: NoAction, map: "FK_BoilRecords_Authors")
  Batchs        Batchs     @relation(fields: [BatchId], references: [BatchPK], onUpdate: NoAction, map: "FK_BoilRecords_Batchs")
  Operations    Operations @relation(fields: [OperationId], references: [OperationPK], onUpdate: NoAction, map: "FK_BoilRecords_Operations")
}

model Boils {
  BoilPK    Int      @id(map: "PK__Boils__4DD049A086850EE0") @default(autoincrement())
  BatchPK   Int
  ProductId String   @db.Char(6)
  Quantity  Decimal  @db.Decimal(9, 5)
  Batchs    Batchs   @relation(fields: [BatchPK], references: [BatchPK], onUpdate: NoAction, map: "FK_Boils_Batchs")
  Products  Products @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_Boils_Products")

  @@index([BatchPK, ProductId], map: "IX_Boils_BatchPK_ProductId")
  @@index([BatchPK, ProductId], map: "IX_Boils_BatchPK_ProductId_Quantity")
  @@index([ProductId], map: "NonClusteredIndex-20250921-151817")
  @@index([BatchPK], map: "NonClusteredIndex-20250921-151853")
}

model BtProducts {
  BtProductPK Int      @id(map: "BtProductsPK") @default(autoincrement())
  BatchPK     Int
  ProductId   String   @db.Char(6)
  Batchs      Batchs   @relation(fields: [BatchPK], references: [BatchPK], onUpdate: NoAction, map: "FK_BtProducts_Batchs")
  Products    Products @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_BtProducts_Products")

  @@index([BatchPK], map: "NonClusteredIndex-20250921-152710")
  @@index([ProductId], map: "NonClusteredIndex-20250921-152722")
}

model CanComments {
  CanCommentPK Int          @id(map: "PK__CanComments") @default(autoincrement())
  Value        String       @db.VarChar(200)
  CanRecords   CanRecords[]
}

model CanLocations {
  CanLocationPK Int      @id(map: "PK__CanLocations") @default(autoincrement())
  CanPK         Int
  PlantPK       Int?
  Transit       Boolean
  AuthorPK      Int
  CreateDate    DateTime @db.DateTime
  Authors       Authors  @relation(fields: [AuthorPK], references: [AuthorPK], onUpdate: NoAction, map: "FK_CanLocations_Authors")
  Cans          Cans     @relation(fields: [CanPK], references: [CanPK], onUpdate: NoAction, map: "FK_CanLocations_Cans")
  Plants        Plants?  @relation(fields: [PlantPK], references: [PlantPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_CanLocations_Plants")
}

model CanRecords {
  CanRecordPK  Int          @id(map: "PK__CanRecords") @default(autoincrement())
  CanPK        Int
  AuthorPK     Int
  BatchPK      Int?
  CanStatePK   Int
  CanCommentPK Int?
  CreateDate   DateTime     @db.DateTime
  Authors      Authors      @relation(fields: [AuthorPK], references: [AuthorPK], onUpdate: NoAction, map: "FK_CanRecords_Authors")
  Batchs       Batchs?      @relation(fields: [BatchPK], references: [BatchPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_CanRecords_Batchs")
  CanComments  CanComments? @relation(fields: [CanCommentPK], references: [CanCommentPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_CanRecords_CanComments")
  Cans         Cans         @relation(fields: [CanPK], references: [CanPK], onUpdate: NoAction, map: "FK_CanRecords_Cans")
  CanStates    CanStates    @relation(fields: [CanStatePK], references: [CanStatePK], onUpdate: NoAction, map: "FK_CanRecords_CanStates")
}

model Cans {
  CanPK         Int            @id(map: "PK__Cans") @default(autoincrement())
  CanName       String         @unique(map: "UC_Cans") @db.VarChar(40)
  CanVolume     Decimal?       @db.Decimal(4, 2)
  CanBarcode    String?        @db.Char(13)
  CanOrderValue Int?
  CanLocations  CanLocations[]
  CanRecords    CanRecords[]
}

model CanStates {
  CanStatePK          Int          @id(map: "PK__CanStates") @default(autoincrement())
  CanStateName        String       @unique(map: "UC_CanStates") @db.VarChar(20)
  CanStateDescription String       @db.VarChar(50)
  isBaseState         Boolean?
  CanStateOrderValue  Int?
  CanRecords          CanRecords[]
}

model Cells {
  CellPK        Int             @id(clustered: false, map: "PK_Cells") @default(autoincrement())
  CellName      String          @db.VarChar(50)
  CellBarcode   String          @db.Char(13)
  PlantPK       Int
  Plants        Plants          @relation(fields: [PlantPK], references: [PlantPK], onUpdate: NoAction, map: "FK_Cells_Plants")
  CellsContains CellsContains[]
}

model CellsContains {
  CellContainPK Int      @id(map: "PK__CellsCon__A93A1471EBF53E7A") @default(autoincrement())
  CellPK        Int
  ProductId     String   @db.Char(6)
  LotId         Int
  Expire        DateTime @db.DateTime
  Cells         Cells    @relation(fields: [CellPK], references: [CellPK], onUpdate: NoAction, map: "FK_CellsContains_Cells")
  Lots          Lots     @relation(fields: [LotId], references: [LotPK], onUpdate: NoAction, map: "FK_CellsContains_Lots")
  Products      Products @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_CellsContains_Products")
}

model Containers {
  ContainerPK   Int          @id(map: "PK__Containe__03791936E88053F7") @default(autoincrement())
  ContainerName String       @unique(map: "UC_Containers") @db.VarChar(50)
  Loads         Loads[]
  Weightings    Weightings[]
}

model Doctypes {
  DoctypePK    Int         @id(map: "PK__Doctypes__377906F23A5FD83E") @default(autoincrement())
  DoctypeName  String      @unique(map: "UC_Doctypes") @db.VarChar(50)
  DoctypeAlias String?     @db.VarChar(50)
  Documents    Documents[]

  @@index([DoctypePK], map: "IX_Doctypes_PK_Alias")
  @@index([DoctypeAlias], map: "NonClusteredIndex-20251008-190821")
}

model Documents {
  DocumentPK   Int          @id(map: "PK__Document__1ABE26513B920059") @default(autoincrement())
  DocumentClid String       @unique(map: "UC_Documents") @db.VarChar(50)
  DoctypePK    Int
  AuthorPK     Int
  CreateDate   DateTime     @db.DateTime
  Plant        String?      @db.NChar(1)
  Acceptance   Acceptance[]
  Authors      Authors      @relation(fields: [AuthorPK], references: [AuthorPK], onUpdate: NoAction, map: "FK_Documents_Authors")
  Doctypes     Doctypes     @relation(fields: [DoctypePK], references: [DoctypePK], onUpdate: NoAction, map: "FK_Documents_Doctypes")
  Loads        Loads[]
  Weightings   Weightings[]

  @@index([DoctypePK], map: "IX_Documents_DoctypePK_AuthorPK_CreateDate")
  @@index([CreateDate, DoctypePK, AuthorPK], map: "IX_Documents_TimeTypeAuthor")
  @@index([DoctypePK], map: "NonClusteredIndex-20251007-135525")
  @@index([CreateDate], map: "NonClusteredIndex-20251007-135548")
  @@index([AuthorPK], map: "NonClusteredIndex-20251007-164141")
}

model InventoryDocs {
  InventoryDocPK Int             @id(map: "PK__InventoryDoc") @default(autoincrement())
  InventoryDate  DateTime        @db.Date
  PlantPK        Int
  Finished       Boolean
  Plants         Plants          @relation(fields: [PlantPK], references: [PlantPK], onUpdate: NoAction, map: "FK_InventoryDocs_Plants")
  InventoryRows  InventoryRows[]
}

model InventoryRows {
  InventoryRowPK Int           @id(map: "PK__InventoryRow") @default(autoincrement())
  InventoryDocPK Int
  ProductId      String        @db.Char(6)
  LotPK          Int
  ExpDate        DateTime      @db.DateTime
  Quantity       Decimal       @db.Decimal(9, 5)
  AuthorPK       Int
  CreateDate     DateTime      @db.DateTime
  Authors        Authors       @relation(fields: [AuthorPK], references: [AuthorPK], onUpdate: NoAction, map: "FK_InventoryRows_Authors")
  InventoryDocs  InventoryDocs @relation(fields: [InventoryDocPK], references: [InventoryDocPK], onUpdate: NoAction, map: "FK_InventoryRows_InventoryDocs")
  Lots           Lots          @relation(fields: [LotPK], references: [LotPK], onUpdate: NoAction, map: "FK_InventoryRows_Lots")
  Products       Products      @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_InventoryRows_Products")
}

model Loads {
  LoadsPK     Int        @id(map: "PK__Loads__E5F45BAA76AA5251") @default(autoincrement())
  DocumentPK  Int
  ContainerPK Int
  BatchPK     Int
  Batchs      Batchs     @relation(fields: [BatchPK], references: [BatchPK], onUpdate: NoAction, map: "FK_Loads_Batchs")
  Containers  Containers @relation(fields: [ContainerPK], references: [ContainerPK], onUpdate: NoAction, map: "FK_Loads_Containers")
  Documents   Documents  @relation(fields: [DocumentPK], references: [DocumentPK], onUpdate: NoAction, map: "FK_Loads_Documents")

  @@index([ContainerPK], map: "NonClusteredIndex-20251002-181429")
  @@index([DocumentPK], map: "NonClusteredIndex-20251002-183149")
  @@index([BatchPK], map: "NonClusteredIndex-20251002-183226")
}

model Lots {
  LotPK             Int               @id(map: "PK__Lots__416CB6F922676298") @default(autoincrement())
  LotName           String            @unique(map: "UC_Lots") @db.VarChar(50)
  ProductId         String            @db.Char(6)
  SellerPK          Int?
  ManufacturerPK    Int?
  ManufacturerLotPK Int?
  TradeMarkPK       Int?
  Acceptance        Acceptance[]
  CellsContains     CellsContains[]
  InventoryRows     InventoryRows[]
  ManufacturerLots  ManufacturerLots? @relation(fields: [ManufacturerLotPK], references: [ManufacturerLotPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_Lots_ManufacturerLots")
  Manufacturers     Manufacturers?    @relation(fields: [ManufacturerPK], references: [ManufacturerPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_Lots_Manufacturers")
  Products          Products          @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_Lots_Products")
  Sellers           Sellers?          @relation(fields: [SellerPK], references: [SellerPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_Lots_Sellers")
  Trademarks        Trademarks?       @relation(fields: [TradeMarkPK], references: [TrademarkPK], onDelete: NoAction, onUpdate: NoAction, map: "FK_Lots_Trademarks")
  Weightings        Weightings[]

  @@index([ProductId], map: "NonClusteredIndex-20251002-183318")
}

