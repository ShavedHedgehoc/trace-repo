{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@repo/db": [
        "../db/src/index.ts"
      ],
      "@repo/schemas": [
        "../schemas/src/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../schemas"
    }
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}